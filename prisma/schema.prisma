// Prisma Schema — AI Fitness & Nutrition Coach
// Auth.js v5 (NextAuth v5) compatible models

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Auth.js v5 Required Models ─────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String    @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  role                String    @default("USER")
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  // Fitness profile
  profile         FitnessProfile?
  workoutPlans    WorkoutPlan[]
  workoutProgress WorkoutProgress[]
  nutritionPlans  NutritionPlan[]
  nutritionLogs   NutritionLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App-Specific Models ─────────────────────────────────────────────────────

model FitnessProfile {
  id     String @id @default(cuid())
  userId String @unique

  // Step 1: Personal Info
  age      Int?
  gender   String? // SIMULATED ENUM
  heightCm Float?
  weightKg Float?

  // Step 2: Fitness Profile
  fitnessLevel  String? // SIMULATED ENUM
  activityLevel String? // SIMULATED ENUM
  fitnessGoal   String? // SIMULATED ENUM
  goalWeight    Float?

  // Step 3: Workout Preferences
  workoutDaysPerWeek   Int?
  workoutDuration      Int?
  preferredWorkoutTime String? // SIMULATED ENUM
  equipment            String? // JSON stringified array of strings

  // Step 4: Nutrition
  dietaryPref      String? // SIMULATED ENUM
  foodAllergies    String?
  foodRestrictions String?

  // Step 5: Health
  injuries          String?
  medicalConditions String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkoutPlan {
  id                 String   @id @default(cuid())
  userId             String
  weekNumber         Int
  title              String
  goal               String
  workoutDaysPerWeek Int
  estimatedDuration  Int
  planJson           String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress WorkoutProgress[]

  @@unique([userId, weekNumber])
  @@index([userId])
}

model WorkoutProgress {
  id            String    @id @default(cuid())
  workoutPlanId String
  userId        String
  day           String
  exerciseName  String
  completed     Boolean   @default(false)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workoutPlanId, userId, day, exerciseName])
  @@index([userId])
  @@index([workoutPlanId])
}

model NutritionPlan {
  id             String   @id @default(cuid())
  userId         String
  weekNumber     Int
  title          String
  targetCalories Int
  proteinGoal    Int
  carbsGoal      Int
  fatGoal        Int
  waterGoalMl    Int
  planJson       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekNumber])
  @@index([userId])
}

model NutritionLog {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime
  waterIntakeMl Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ─── Enums (Simulated for SQLite) ──────────────────────────────────────────────────

// SQLite doesn't support enums natively in Prisma, so we use String
// USER
// ADMIN
